---
export interface Props {
  title?: string;
  description?: string;
}
const { title = 'Guna Prasaad', description = 'PM at Meta. Builder. Writer.' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" href="/favicon.ico" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --text: #1a1a1a;
      --muted: #666;
      --border: #e5e5e5;
      --bg: #fff;
      --max-w: 640px;
      --font: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif, "Apple Color Emoji";
    }

    html { font-size: 17px; }

    body {
      font-family: var(--font);
      color: var(--text);
      background: var(--bg);
      line-height: 1.65;
      padding: 0 1.25rem;
    }

    a { color: var(--text); }
    a:hover { opacity: 0.7; }

    header {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 1.75rem 0 1.25rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 1px solid var(--border);
    }

    header .logo {
      font-weight: 600;
      font-size: 1rem;
      text-decoration: none;
      letter-spacing: -0.01em;
    }

    header nav {
      display: flex;
      gap: 1.5rem;
    }

    header nav a {
      font-size: 0.9rem;
      color: var(--muted);
      text-decoration: none;
    }

    header nav a:hover { color: var(--text); opacity: 1; }

    main {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 2.5rem 0 4rem;
    }

    footer {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 1.5rem 0;
      border-top: 1px solid var(--border);
      font-size: 0.82rem;
      color: var(--muted);
    }
  </style>
</head>
<body>
  <header>
    <a class="logo" href="/">gunaprsd</a>
    <nav>
      <a href="/writing">Writing</a>
      <a href="/#about">About</a>
    </nav>
  </header>
  <main>
    <slot />
  </main>
  <footer>
    &copy; 2026 gunaprsd
  </footer>
</body>
</html>
