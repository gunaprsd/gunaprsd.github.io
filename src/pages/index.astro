---
import Base from '../layouts/Base.astro';
---
<Base title="Guna Prasaad" description="PM at Meta. Builder. Writer.">
  <section class="hero">
    <div class="hero-inner">
      <img src="/assets/me.jpg" alt="Guna Prasaad" class="avatar" />
      <h1>Guna Prasaad</h1>
      <p class="bio">
        Product Manager at Meta. Formerly CS PhD at UW.<br />
        I like building things and writing about them.
      </p>
      <div class="ctas">
        <a href="/writing" class="btn btn-primary">Writing</a>
        <a href="https://www.linkedin.com/in/guna-prasaad-1479a450" target="_blank" rel="noopener" class="btn btn-secondary">LinkedIn</a>
      </div>
      <div class="secondary-links">
        <a href="https://github.com/gunaprsd" target="_blank" rel="noopener">GitHub</a>
        <span class="dot">·</span>
        <a href="https://twitter.com/gunaprsd" target="_blank" rel="noopener">Twitter</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 11rem);
    padding: 3rem 1.5rem;
  }

  .hero-inner {
    max-width: 360px;
    width: 100%;
    text-align: center;
  }

  .avatar {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    object-fit: cover;
    display: block;
    margin: 0 auto;
    border: 2px solid var(--border);
  }

  h1 {
    font-size: clamp(1.3rem, 4vw, 1.6rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    margin-top: 1.5rem;
    line-height: 1.2;
  }

  .bio {
    font-size: 0.95rem;
    color: var(--muted);
    margin-top: 0.85rem;
    line-height: 1.6;
  }

  .ctas {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.65rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.5rem 1.1rem;
    border-radius: 6px;
    transition: opacity 0.15s, background 0.15s;
    white-space: nowrap;
    text-decoration: none;
  }

  .btn-primary {
    background: var(--text);
    color: var(--bg);
    border: 1px solid transparent;
  }

  .btn-primary:hover {
    opacity: 0.8;
  }

  .btn-secondary {
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border);
  }

  .btn-secondary:hover {
    background: #f5f5f5;
  }

  .secondary-links {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1.25rem;
    font-size: 0.8rem;
    color: var(--muted);
  }

  .secondary-links a {
    color: var(--muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .secondary-links a:hover {
    color: var(--text);
  }

  .dot {
    opacity: 0.4;
  }
</style>
