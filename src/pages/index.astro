---
import Base from '../layouts/Base.astro';
---
<Base title="Guna Prasaad" description="PM at Meta. Builder. Writer.">
  <section>
    <div class="hero-wrap">
      <div class="hero-inner">

        <!-- Photo (replaces the bear SVG) -->
        <img src="/assets/me.jpg" alt="Guna Prasaad" class="avatar" />

        <!-- Name -->
        <h1>Guna Prasaad</h1>

        <!-- Bio -->
        <p class="bio">
          Product Manager at Meta. Formerly CS PhD at UW.<br />
          I like building things and writing about them.
        </p>

        <!-- CTAs -->
        <div class="ctas">
          <a href="/writing" class="btn btn-primary">Writing</a>
          <a href="https://www.linkedin.com/in/guna-prasaad-1479a450" target="_blank" rel="noopener" class="btn btn-secondary">LinkedIn</a>
        </div>

        <!-- Secondary links -->
        <div class="links">
          <a href="https://github.com/gunaprsd" target="_blank" rel="noopener">GitHub</a>
          <span>·</span>
          <a href="https://twitter.com/gunaprsd" target="_blank" rel="noopener">Twitter</a>
        </div>

      </div>
    </div>
  </section>
</Base>

<style>
  /* Bearnie-exact layout:
     - full width, px-8, py-12
     - lg: exact viewport height minus header+footer (~11.5rem)
     - flex column, justify-center
     - inner: max-w-sm (384px), centered, text-center
  */

  .hero-wrap {
    width: 100%;
    padding: 3rem 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  @media (min-width: 1024px) {
    .hero-wrap {
      height: calc(100vh - 11.5rem);
      padding: 3rem 2rem;
    }
  }

  .hero-inner {
    max-width: 384px; /* max-w-sm */
    width: 100%;
    margin: 0 auto;
    text-align: center;
    text-wrap: balance;
  }

  /* Photo — same size as bearnie's bear: size-12 (3rem) → lg:size-20 (5rem) */
  .avatar {
    width: 3rem;
    height: 3rem;
    border-radius: 9999px;
    object-fit: cover;
    object-position: center;
    display: block;
    margin: 0 auto;
  }

  @media (min-width: 1024px) {
    .avatar {
      width: 5rem;
      height: 5rem;
    }
  }

  /* h1 — text-lg sm:text-xl md:text-2xl font-medium tracking-tight mt-12 */
  h1 {
    font-size: 1.125rem;
    font-weight: 500;
    letter-spacing: -0.025em;
    margin-top: 3rem;
    line-height: 1.375;
    color: var(--foreground);
  }

  @media (min-width: 640px) {
    h1 { font-size: 1.25rem; }
  }

  @media (min-width: 768px) {
    h1 { font-size: 1.5rem; }
  }

  /* Bio — text-base text-muted-foreground mt-4 */
  .bio {
    font-size: 1rem;
    color: var(--muted-foreground);
    margin-top: 1rem;
    line-height: 1.5;
  }

  /* CTAs — flex items-center gap-2.5 mt-12 justify-center */
  .ctas {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin-top: 3rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Buttons — h-9 px-4 rounded-md text-sm font-medium */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 2.25rem;
    padding: 0 1rem;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
    white-space: nowrap;
    transition: opacity 0.15s, background 0.15s;
    cursor: pointer;
  }

  .btn-primary {
    background: var(--primary);
    color: var(--primary-foreground);
  }

  .btn-primary:hover { opacity: 0.85; }

  .btn-secondary {
    background: var(--background);
    color: var(--foreground);
    border: 1px solid var(--input);
  }

  .btn-secondary:hover {
    background: var(--secondary);
  }

  /* Secondary links — mt-8 text-xs text-muted-foreground */
  .links {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 2rem;
    font-size: 0.75rem;
    color: var(--muted-foreground);
    font-family: 'Geist Mono', monospace;
  }

  .links a {
    color: var(--muted-foreground);
    transition: color 0.15s;
  }

  .links a:hover { color: var(--foreground); }

  .links span { opacity: 0.4; }
</style>
