---
import Base from '../layouts/Base.astro';
---
<Base title="Guna Prasaad" description="PM at Meta. Builder. Writer." fullbleed={true}>
  <section>
    <!--
      Bearnie exact structure:
      div.outer  → max-w-screen, mx-auto, px-8, w-full, py-12, lg:h-[calc(100vh-11.5rem)], flex, flex-col, justify-center
      div.inner  → max-w-sm, text-center, mx-auto, text-balance
    -->
    <div class="outer">
      <div class="inner">

        <img src="/assets/me.jpg" alt="Guna Prasaad" class="avatar" />

        <!-- text-lg sm:text-xl md:text-2xl font-medium tracking-tight mt-12 -->
        <h1>Guna Prasaad</h1>

        <!-- text-base text-muted mt-4 -->
        <p class="bio">
          Product Manager at Meta. Formerly CS PhD at UW.<br />
          I like building things and writing about them.
        </p>

        <!-- flex items-center gap-2.5 mt-12 justify-center -->
        <div class="ctas">
          <!-- bg-primary text-primary-foreground h-9 px-4 text-sm rounded-md font-medium -->
          <a href="/writing" class="btn btn-primary">Writing</a>
          <!-- border border-input bg-background h-9 px-4 text-sm rounded-md font-medium -->
          <a href="https://www.linkedin.com/in/guna-prasaad-1479a450" target="_blank" rel="noopener" class="btn btn-secondary">LinkedIn</a>
        </div>

        <!-- mt-8 text-xs text-muted font-mono — repurposed as secondary links -->
        <p class="sub-links">
          <a href="https://github.com/gunaprsd" target="_blank" rel="noopener">GitHub</a>
          &nbsp;·&nbsp;
          <a href="https://twitter.com/gunaprsd" target="_blank" rel="noopener">Twitter</a>
        </p>

      </div>
    </div>
  </section>
</Base>

<style>
  /* outer: max-w-screen mx-auto px-8 w-full py-12 flex flex-col justify-center
     + lg:h-[calc(100vh-11.5rem)] */
  .outer {
    width: 100%;
    max-width: 100vw;
    margin: 0 auto;
    padding: 3rem 2rem;   /* py-12 px-8 */
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  @media (min-width: 1024px) {
    .outer {
      height: calc(100vh - 11.5rem); /* lg:h-[calc(100vh-11.5rem)] */
    }
  }

  /* inner: max-w-sm text-center mx-auto text-balance */
  .inner {
    max-width: 24rem; /* max-w-sm = 384px = 24rem */
    text-align: center;
    margin: 0 auto;
    text-wrap: balance;
  }

  /* avatar: size-12 mx-auto (lg:size-20) rounded-full object-cover */
  .avatar {
    width: 3rem;   /* size-12 = 12 * 0.25rem = 3rem */
    height: 3rem;
    margin: 0 auto;
    display: block;
    border-radius: 9999px;
    object-fit: cover;
    object-position: center;
  }

  @media (min-width: 1024px) {
    .avatar {
      width: 5rem;   /* lg:size-20 = 20 * 0.25rem = 5rem */
      height: 5rem;
    }
  }

  /* h1: text-lg sm:text-xl md:text-2xl font-medium tracking-tight mt-12 */
  h1 {
    font-size: 1.125rem;
    font-weight: 500;
    letter-spacing: -0.025em;
    margin-top: 3rem; /* mt-12 */
    line-height: 1.375;
    color: var(--text);
  }

  @media (min-width: 640px) {
    h1 { font-size: 1.25rem; } /* sm:text-xl */
  }

  @media (min-width: 768px) {
    h1 { font-size: 1.5rem; }  /* md:text-2xl */
  }

  /* bio: text-base text-muted-foreground mt-4 */
  .bio {
    font-size: 1rem;
    color: var(--muted);
    margin-top: 1rem; /* mt-4 */
    line-height: 1.5;
  }

  /* ctas: flex items-center gap-2.5 mt-12 justify-center */
  .ctas {
    display: flex;
    align-items: center;
    gap: 0.625rem;  /* gap-2.5 */
    margin-top: 3rem; /* mt-12 */
    justify-content: center;
  }

  /* btn: inline-flex items-center justify-center whitespace-nowrap font-medium
          h-9 px-4 text-sm rounded-md transition-colors */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    white-space: nowrap;
    font-weight: 500;
    height: 2.25rem;   /* h-9 */
    padding: 0 1rem;   /* px-4 */
    font-size: 0.875rem; /* text-sm */
    border-radius: 0.375rem; /* rounded-md */
    transition: background 0.15s, opacity 0.15s;
    cursor: pointer;
    text-decoration: none;
    border: none;
  }

  /* btn-primary: bg-primary text-primary-foreground hover:bg-primary/90 */
  .btn-primary {
    background: var(--text);
    color: var(--bg);
  }

  .btn-primary:hover { opacity: 0.85; }

  /* btn-secondary: border border-input bg-background hover:bg-accent */
  .btn-secondary {
    background: var(--bg);
    color: var(--text);
    border: 1px solid var(--border);
  }

  .btn-secondary:hover { background: #f5f5f5; }

  /* sub-links: mt-8 text-xs text-muted font-mono */
  .sub-links {
    margin-top: 2rem; /* mt-8 */
    font-size: 0.75rem; /* text-xs */
    color: var(--muted);
    font-family: monospace;
  }

  .sub-links a {
    color: var(--muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .sub-links a:hover { color: var(--text); }
</style>
